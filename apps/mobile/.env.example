# =============================================================================
# Trava-App Mobile (Expo) — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Only EXPO_PUBLIC_* values are exposed to the client bundle; do not put
# secrets here.
# =============================================================================

# --- Pusher (realtime, public client keys) ---
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=

# NOTE: The backend API base URL is currently hardcoded in
# src/services/api.ts (API_BASE). See docs/TECH_DEBT.md for the plan to move
# it to EXPO_PUBLIC_API_BASE.
