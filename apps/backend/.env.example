# =============================================================================
# Trava-App Backend — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# All values below are placeholders only.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Authentication (better-auth) ---
# Generate a strong random secret (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (PostgreSQL) ---
# DATABASE_URL is the pooled connection; DIRECT_URL is the direct (non-pooled)
# connection used by Prisma Migrate.
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public
DIRECT_URL=postgresql://user:password@host:5432/dbname?schema=public

# --- Pusher (realtime) ---
# NEXT_PUBLIC_* values are public (client) keys; PUSHER_APP_ID/PUSHER_SECRET are secret.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
PUSHER_APP_ID=
PUSHER_SECRET=

# --- SMTP (email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Google Generative AI ---
GOOGLE_GENAI_API_KEY=

# --- AWS / S3 (object storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_ENDPOINT_URL_S3=
AWS_ENDPOINT_URL_IAM=
NEXT_PUBLIC_S3_BUCKET_NAME_IMAGES=

# --- Scheduled jobs ---
# Shared secret required by cron/scheduled HTTP endpoints.
CRON_SECRET=

# --- Optional / legacy (Next.js migration leftovers) ---
# NEXT_PUBLIC_APP_URL=
# NEXT_PUBLIC_ENABLE_PERF_LOGS=false
