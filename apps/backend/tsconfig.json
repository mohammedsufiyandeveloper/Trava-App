{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@/generated/prisma": ["./src/generated/prisma"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "tuskerapp", "dist", "src/lib/store", "src/lib/actions", "src/lib/utils/extract-filter-options.ts"]
}