{
  "name": "@trava/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsup src/index.ts --format esm --target node20 --minify --clean --splitting false --external @prisma/client,better-auth --out-dir api",
    "start": "tsx src/server.ts",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:seed": "tsx prisma/seed-units.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "@google/generative-ai": "^0.24.0",
    "@hono/node-server": "^2.0.3",
    "@prisma/client": "6.19.0",
    "better-auth": "^1.3.27",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^6.1.0",
    "hono": "^4.12.12",
    "nodemailer": "^7.0.7",
    "prettier": "^3.6.2",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "slugify": "^1.6.6",
    "tailwind-merge": "^3.3.1",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.34",
    "@eslint/js": "^9.38.0",
    "@types/node": "^20.19.25",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "globals": "^15.15.0",
    "pg": "^8.20.0",
    "prisma": "6.19.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.15"
  }
}
