# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# OS / editor
.DS_Store
*.pem
*.swp

# dependencies (any workspace)
node_modules/
.pnp
.pnp.*

# env files — never commit real secrets; .env.example is allowed
.env
.env.*
!.env.example
.env*.local

# typescript / build info
*.tsbuildinfo

# testing / coverage
coverage/

# vercel
.vercel

# logs / debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# tool output / scratch
lint_results.json

# migration backups (recovery bundles/patches — never commit)
/_backup/

# NOTE: apps/backend/api and apps/backend/dist are intentionally tracked
# (Vercel deploy bundles). Generated Prisma client is ignored per-app.
